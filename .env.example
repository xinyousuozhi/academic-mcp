# Academic MCP 환경 설정
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env

# ============================================================
# 활성화할 Provider (쉼표 구분)
# ============================================================
# 키 없이 사용 가능: kci, oak, kostma
# 키 필요: losi, hgis, nl, cinii
ENABLED_PROVIDERS=kci,oak,kostma

# ============================================================
# API 키 (필요한 것만 입력)
# ============================================================

# 국회도서관 입법정보 (LOSI)
# 발급: https://open.assembly.go.kr/
LOSI_API_KEY=

# 국사편찬위원회 역사지리정보 (HGIS)
# 발급: https://hgis.history.go.kr/
HISTORY_API_KEY=

# 국립중앙도서관 (NL) - 공공데이터포털 경유
# 발급: https://www.data.go.kr/ 에서 "국립중앙도서관" 검색
DATA_GO_KR_API_KEY=

# CiNii Research (일본)
# 발급: https://support.nii.ac.jp/en/cinii/api/developer
CINII_API_KEY=
